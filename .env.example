# The Odds API
ODDS_API_KEY=tu_api_key_aqui

# API-Football (gratis: https://dashboard.api-football.com)
FOOTBALL_API_KEY=tu_football_api_key_aqui

# Telegram Bot
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Bankroll
BANKROLL_INICIAL=10000
MONEDA=CRC

# Deportes (4 × 2 regiones = 8 créditos por ejecución)
SPORTS=soccer_epl,soccer_la_liga,basketball_nba,tennis_atp
REGIONS=eu,us

# Kelly Criterion
KELLY_FRACTION=0.25

# Apuestas
MIN_EV_PERCENTAGE=2
MIN_SCORE=50
MAX_APUESTAS_POR_DIA=10

# Config
NODE_ENV=development
EXEC_INTERVAL=30
DB_PATH=./bets.db
MAX_CREDITOS_RUN=30
